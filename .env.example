# ─── Frontend Environment Variables ────────────────────────────────────────
# Set these in Vercel Dashboard → Project → Settings → Environment Variables

# Required. Full URL to your Render backend INCLUDING the /api segment.
# No trailing slash. api.ts constructs endpoints as: ${NEXT_PUBLIC_API_URL}/chat
#
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000/api
#
# Vercel production (set this in Vercel dashboard, not here):
# NEXT_PUBLIC_API_URL=https://website-rag-qxbv.onrender.com/api


# ─── Backend Environment Variables ─────────────────────────────────────────
# Set these in Render Dashboard → website-rag-backend → Environment

GEMINI_API_KEY=your_google_gemini_api_key

# Comma-separated list of allowed frontend origins.
# Must include your actual Vercel deployment URL (no trailing slash).
# Example:
#   CORS_ORIGINS=https://website-rag-abc123.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

VECTOR_STORE_PATH=data/vector_store
LOG_LEVEL=INFO
